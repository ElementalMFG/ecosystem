# Build outputs
build/
build_*/
build-host/
dist/
out/
target/
# ...but the on-target Unity test app (S-02-015) is source, not a build dir; its
# build/ and sdkconfig are still ignored by the rules above/below.
!firmware/test/target/
node_modules/
.dart_tool/
.pub-cache/
__pycache__/
*.pyc
*.pyo

# ESP-IDF
sdkconfig
sdkconfig.old
managed_components/
dependencies.lock
.pio/
.pioenvs/

# Rust
Cargo.lock
!/**/Cargo.lock.example

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Secrets / keys — NEVER commit
*.key
*.pem
*.der
*.p12
*.pfx
secrets/
keys/
!keys/README.md
.env
.env.*
*.env
!.env.example

# Firmware artifacts
*.bin
*.elf
!bootloader/*.bin
!bootloader/*.elf

# Logs
*.log
logs/

# Coverage
coverage/
*.gcda
*.gcno
*.gcov
lcov.info

# Docs build
_site/
site/
book/
docs/_build/

# Companion apps
android/app/build/
ios/Pods/
ios/build/
*.apk
*.aab
*.ipa
*.dSYM

# Fuzz output
crashes/
corpus/
fuzz-*/

# Claude Code — personal/local state (never commit)
.claude/settings.local.json
.claude/worktrees/
CLAUDE.local.md

# Root-level note/scratch text files are never repo content (accidental-publication guard)
/*.txt
