{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "bash tools/claude/statusline.sh"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/claude/session-brief.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash tools/claude/format-c-hook.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(make lite:*)",
      "Bash(make lint-docs:*)",
      "Bash(python3 tools/lint-docs.py:*)",
      "Bash(python3 tools/gen-stories-index.py:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git check-ignore:*)",
      "Bash(cmake:*)",
      "Bash(ctest:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push origin main:*)",
      "Bash(git fetch:*)",
      "Bash(python3 tools/allocation.py:*)",
      "Bash(python3 tools/covenant-check.py:*)",
      "Bash(python3 tools/task-policy-check.py:*)",
      "Bash(python3 tools/board-parity.py:*)"
    ],
    "deny": [
      "Edit(docs/portfolio/STORIES_INDEX.md)",
      "Write(docs/portfolio/STORIES_INDEX.md)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/id_rsa*)"
    ]
  }
}
